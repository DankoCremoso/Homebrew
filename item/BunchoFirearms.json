    "item": [
		{
			"name": "Palm Pistol",
			"source": "BoF",
			"type": "R|XPHB",
			"weaponCategory": "martial",
			"weapon": true,
            "rarity": "none",
			"weight": 1,
			"value": 5000,
			"property": ["A", "L", "RLD", "MSF"],
			"weaponMastery": "Nick|XPHB",
			"range": "20/60",
			"dmg1": "1d8",
			"dmgType": "P",
			"hasFluffImages": true,
			"entries": [
				"Properties: {@itemProperty A|XPHB|Ammunition} (Range 40/160), {@itemProperty L|XPHB|Light}, {@itemProperty RLD|BoF|Reload} 1, {@itemProperty MSF|BoF|Misfire} 1",
				"{@b Mastery: Nick.} When you make the extra attack of the {@itemProperty L|XPHB|Light} property, you can make it as part of the {@action Attack|XPHB} action instead of as a Bonus Action. You can make this extra attack only once per turn."
			]
		}
    ],
    "itemProperty": [
        {
			"abbreviation": "RLD",
			"source": "BoF",
			"name": "Reload",
			"entries": [
            "{@b Reload.} The weapon can be fired a number of times equal to its Reload score before you must spend 1 {@action Attack|XPHB} or 1 {@variantrule Action|XPHB} to reload. You must have one free hand to reload a firearm."
        	]
		},
        {
			"abbreviation": "MSF",
			"source": "BoF",
			"name": "Misfire",
			"entries": [
            "{@b Misfire.} Whenever you make an attack roll with a firearm, and the dice roll is equal to or lower than the weapon's Misfire score, the weapon misfires. The attack misses, and the weapon cannot be used again until you spend an {@variantrule Action|XPHB} to try to repair it.",
			"To repair your firearm, you must make a succesfull {@item Tinker's Tools|XPHB} check (DC equal to 8 + misfire score). If your check fails, the weapon is broken and must be mended out of combat at a quarter of the cost of the firearm. Creatures who use a firearm without being proficient increase the weapon's misfire score by 1."
        ]
		},
        {
			"abbreviation": "EXP",
			"source": "BoF",
			"name": "Explosive",
			"entries": [
				"{@b Explosive.} Upon a hit, everything within 5 ft of the target must make a Dexterity saving throw (DC equal to 8 + your {@variantrule Proficiency|XPHB} Bonus + your Dexterity modifier) or suffer {@dice 1d8} fire damage. If the weapon misses, the ammunition fails to detonate, or bounces away harmlessly before doing so."
			]
		}
    ],
